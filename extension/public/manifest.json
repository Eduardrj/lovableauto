{
  "manifest_version": 3,
  "name": "LovableAuto",
  "description": "AI-powered code editing for Lovable projects via GitHub",
  "version": "1.0.0",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://api.github.com/*",
    "http://104.131.110.134:3001/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lovable.dev/*"
      ],
      "js": [
        "lovable-detector.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://104.131.110.134/*"
      ],
      "js": [
        "auth-callback.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "LovableAuto"
  }
}