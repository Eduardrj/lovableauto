# ─── Backend ───
NODE_ENV=development
PORT=3001

# ─── Database (Supabase / Postgres) ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lovableauto

# ─── Redis (BullMQ) ───
REDIS_URL=redis://localhost:6379

# ─── GitHub OAuth ───
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ─── JWT ───
JWT_SECRET=change-me-to-a-strong-random-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (for tokens at rest) ───
ENCRYPTION_KEY=32-byte-hex-key-for-aes-256-encryption

# ─── LLM Provider ───
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ─── Extension ───
EXTENSION_ORIGIN=chrome-extension://your-extension-id

# ─── Backend URL (used by extension) ───
VITE_API_URL=http://localhost:3001
